# Trellis-local noise (skeleton-managed; scoped to .trellis/ only).
# The project's own root .gitignore stays project-owned — this file only
# keeps trellis runtime/cache state out of git for freshly rendered repos.
__pycache__/
*.pyc
.runtime/
.developer
.current-task
.session-id
.ralph-state.json
.plan-log
.backup-*/
